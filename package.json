{
  "name": "git-cli-stack",
  "version": "0.1.3",
  "description": "Manage stacked pull requests with a git CLI and MCP server.",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "git-stack": "./dist/cli.js",
    "stack": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage .vitest-tmp",
    "dev": "tsx src/cli.ts",
    "mcp": "tsx src/cli.ts mcp",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "git",
    "stack",
    "pull-request",
    "mcp"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@octokit/rest": "^22.0.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.1",
    "js-yaml": "^4.1.0",
    "ora": "^9.0.0",
    "simple-git": "^3.28.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
